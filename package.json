{
    "name": "defauth",
    "version": "2.3.1",
    "description": "A TypeScript OIDC authentication library with support for JWT and opaque tokens",
    "keywords": [
        "oidc",
        "openid",
        "openid-connect",
        "oauth2",
        "jwt",
        "authentication",
        "authorization",
        "token",
        "security",
        "typescript",
        "backend",
        "client",
        "introspection",
        "userinfo",
        "middleware",
        "express",
        "node",
        "spa",
        "rest-api"
    ],
    "homepage": "https://github.com/JulianCissen/defauth",
    "bugs": "https://github.com/JulianCissen/defauth/issues",
    "repository": {
        "type": "git",
        "url": "https://github.com/JulianCissen/defauth"
    },
    "license": "MIT",
    "author": "Julian Cissen",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist/**/*"
    ],
    "scripts": {
        "prebuild": "npm run clean",
        "build": "tsc -p tsconfig.build.json",
        "build:watch": "tsc -p tsconfig.build.json --watch",
        "clean": "rm -rf dist",
        "format": "prettier --write src/**/*.{ts,json}",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "prepublishOnly": "npm run build",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest"
    },
    "dependencies": {
        "jose": "^6.0.11",
        "openid-client": "^6.5.0",
        "zod": "^3.25.28"
    },
    "devDependencies": {
        "@types/node": "^22.19.18",
        "@vitest/coverage-v8": "^3.1.0",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-package-json": "^0.91.2",
        "eslint-plugin-prettier": "^5.4.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "prettier": "^3.5.3",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.59.2",
        "vitest": "^3.1.0"
    },
    "engines": {
        "node": "^22.12.0"
    }
}
